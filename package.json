{
  "name": "dhungesanghu-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install-all": "npm install && npm install --prefix dhungesang_backend && npm install --prefix dhungesangahu-frontend",
    "backend": "npm run dev --prefix dhungesang_backend",
    "frontend": "npm run dev --prefix dhungesangahu-frontend",
    "dev": "concurrently --kill-others \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
